# TRIPHOTOIA environment variables
# Copy this file to .env.local and fill values only when cloud mode is needed.

# Supabase is optional. Without these values, the app stays in local mode.
# Create a project at https://supabase.com, then copy Settings > API > Project URL.
VITE_SUPABASE_URL=https://xxxx.supabase.co

# Use the public anon key only.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Never add a service role key to a Vite/frontend env file.
# Service role keys belong only on trusted servers or workers.

# Worker/VPS only. Do not expose these values to Vite or the browser.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=service-role-key
WORKER_ID=treephoto-worker-1
WORKER_POLL_INTERVAL_MS=5000

# Cloud smoke check (`pnpm smoke:cloud`). Uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY
# above. Without TREEPHOTO_SMOKE_CONFIRM=1 the script only prints its plan (dry-run).
# Set to 1 ONLY against a disposable staging project — it writes and deletes rows.
TREEPHOTO_SMOKE_CONFIRM=0

# Semantic embeddings (Sprint 16). Worker/VPS only.
# Image processor for thumbnail / quality / perceptual-hash jobs (P0-5).
#   stub  = simulé (chemin sans vraie miniature, score par défaut, hash du nom) —
#           dev/CI uniquement ; le worker REFUSE de démarrer en production avec stub
#   sharp = vrai moteur pixel (libvips, non encore câblé) — requis en production
IMAGE_PROCESSOR=stub

# Provider for the semantic_embedding job:
#   deterministic = model-free stand-in (default, keeps the pipeline working in dev/CI)
#   clip          = real CLIP image+text embeddings via @xenova/transformers (VPS only;
#                   run `pnpm add @xenova/transformers` first — see worker/README.md)
EMBEDDING_PROVIDER=deterministic
# Embedding dimension — must match the vector(N) column in the embeddings migration (512 for CLIP ViT-B/32).
EMBEDDING_DIMENSIONS=512
# Model label/id. For clip use a Transformers.js model id, e.g. Xenova/clip-vit-base-patch32.
EMBEDDING_MODEL=deterministic-v1

# Face detection (Sprint 17). Worker/VPS only. Strict opt-in per project.
#   deterministic = model-free stand-in (default)
#   disabled      = detection off — produces zero faces, fabricates nothing (privacy/GDPR opt-out)
#   onnx          = real SCRFD/ArcFace via onnxruntime-node (documented extension point, not wired)
FACE_PROVIDER=deterministic
# Face embedding dimension — must match the vector(N) column in the faces migration.
FACE_EMBEDDING_DIMENSIONS=128
